# PostgreSQL Database (Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/offergenpython"

# Anthropic Claude API
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Perplexity API for web research
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY="pplx-..."

# Google Gemini API for image generation
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy..."

# Optional: override Gemini model (default: gemini-3.1-flash-image-preview)
# GEMINI_IMAGE_MODEL="gemini-3.1-flash-image-preview"

# Gmail OAuth 2.0 (for draft creation)
# Get from: https://console.cloud.google.com/
GMAIL_CLIENT_ID="..."
GMAIL_CLIENT_SECRET="..."
GMAIL_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"

# Optional: NEXTAUTH_SECRET (for production)
# NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
